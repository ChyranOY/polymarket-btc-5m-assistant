# ---- Polymarket endpoints ----
POLYMARKET_SERIES_SLUG=btc-up-or-down-5m
POLYMARKET_SERIES_ID=10684
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
CLOB_HOST=https://clob.polymarket.com
POLYMARKET_WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ---- Live-trading credentials (leave blank for paper-only) ----
PRIVATE_KEY=
FUNDER_ADDRESS=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=
SIGNATURE_TYPE=2
CHAIN_ID=137

# ---- Trading config ----
TRADING_MODE=paper                 # paper | live
TRADING_ENABLED_ON_BOOT=false
STAKE_PCT=0.08
MIN_STAKE_USD=25
MAX_STAKE_USD=250
STARTING_BALANCE=1000
STOP_LOSS_PCT=0.30
CHEAP_SIDE_MIN=0.15
CHEAP_SIDE_MAX=0.45
TIME_LEFT_MIN_MINUTES=1.5
TRADING_HOURS_START_PST=6
TRADING_HOURS_END_PST=17
ALLOW_WEEKENDS=false

# ---- Persistence ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PAPER_LEDGER_PATH=./live_trading/paper_ledger.json

# ---- HTTP server ----
HTTP_PORT=3000
CONTROL_TOKEN=

# ---- Logging ----
RUST_LOG=info,polymarket_btc_5m=debug
